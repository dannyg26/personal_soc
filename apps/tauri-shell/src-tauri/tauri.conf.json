{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Threat-Guard",
  "version": "0.1.0",
  "identifier": "com.threat-guard.app",
  "build": {
    "frontendDist": "../../desktop-ui/dist",
    "devUrl": "http://localhost:43125",
    "beforeDevCommand": "npm --prefix apps/desktop-ui run dev",
    "beforeBuildCommand": "npm --prefix apps/desktop-ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Threat-Guard",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Threat-Guard",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
